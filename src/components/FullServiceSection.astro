---
interface Props {
  eyebrow: string;
  heading: string;
  body: string;
  cta: { href: string; label: string };
  items: Array<{ title: string; description: string; href?: string }>;
}
const { eyebrow, heading, body, cta, items } = Astro.props;
---
<section class="fs-section">
  <div class="fs-outer">
    <div class="fs-text">
      <div class="fs-eyebrow">{eyebrow}</div>
      <h2 class="fs-heading">{heading}</h2>
      <p class="fs-body">{body}</p>
      <a href={cta.href} class="fs-cta-btn">{cta.label}</a>
    </div>
    <div class="fs-img-wrap">
      <img
        src="/images/boost-visibility.avif"
        alt="Venue partner indoor screen"
        class="fs-img"
      />
    </div>
    <div class="fs-cards">
      {items.map((f, i) => (
        <a href={f.href ?? '#'} class="fs-card fs-card-animate" data-i={i} style="background:#fff;border:2px solid #D8E8DC;border-radius:14px;padding:20px;display:flex;gap:16px;align-items:flex-start;text-decoration:none;color:inherit">
          <div class="fs-icon" style="width:42px;height:42px;border-radius:11px;background:#FBEDE4;flex-shrink:0;display:flex;align-items:center;justify-content:center">
            {f.title.toLowerCase().includes('google') ? (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C4622A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            ) : f.title.toLowerCase().includes('website') ? (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C4622A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <line x1="3" y1="9" x2="21" y2="9"/>
                <line x1="9" y1="21" x2="9" y2="9"/>
              </svg>
            ) : f.title.toLowerCase().includes('social') ? (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C4622A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"/>
                <circle cx="6" cy="12" r="3"/>
                <circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
            ) : f.title.toLowerCase().includes('ppc') ? (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C4622A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="4"/>
                <line x1="22" y1="12" x2="16" y2="12"/>
                <line x1="8" y1="12" x2="2" y2="12"/>
                <line x1="12" y1="2" x2="12" y2="8"/>
                <line x1="12" y1="16" x2="12" y2="22"/>
              </svg>
            ) : (
              <div style="width:16px;height:16px;border:2.5px solid #2D5A3D;border-radius:4px"></div>
            )}
          </div>
          <div>
            <h3 class="fs-card-title">{f.title}</h3>
            <p class="fs-card-body">{f.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section & layout ── */
  .fs-section { background: #EBF1E9; padding: 96px 40px; }

  .fs-outer {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  /* ── Text ── */
  .fs-eyebrow {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #C4622A;
    margin-bottom: 16px;
  }
  .fs-heading {
    font-size: 38px;
    line-height: 1.1;
    font-weight: 800;
    color: #1A3325;
    letter-spacing: -0.02em;
  }
  .fs-body {
    font-size: 16px;
    line-height: 1.65;
    color: #4A6655;
    margin-top: 18px;
  }
  .fs-cta-btn {
    display: inline-block;
    margin-top: 28px;
    background: #C4622A;
    color: #fff;
    font-weight: 700;
    font-size: 16px;
    padding: 15px 30px;
    border-radius: 999px;
    box-shadow: 0 4px 6px rgba(140,55,12,0.6);
    text-decoration: none;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }
  .fs-cta-btn:hover { transform: scale(1.06); background: #d8733d; }

  /* ── Image ── */
  .fs-img-wrap { border-radius: 20px; overflow: hidden; min-height: 480px; }
  .fs-img { width: 100%; height: 100%; object-fit: cover; display: block; min-height: 480px; }

  /* ── Cards container ── */
  .fs-cards {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* ── Card ── */
  .fs-card {
    background: #fff;
    border: 2px solid #D8E8DC;
    border-radius: 14px;
    padding: 20px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 4px 8px -2px rgba(26, 51, 37, 0.1);
    /* entry animation initial state */
    opacity: 0;
    transform: translateY(44px);
    transition:
      opacity 1s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.2s ease;
  }
  .fs-card.in-view {
    opacity: 1;
    transform: translateY(0);
  }
  .fs-card.in-view:hover {
    transform: translateY(-10px);
    box-shadow: 0 16px 20px -4px rgba(26, 51, 37, 0.55);
  }
  .fs-icon { transition: none; }

  .fs-card-title { font-size: 16px; font-weight: 800; color: #1A3325; }
  .fs-card-body  { font-size: 14px; line-height: 1.5; color: #4A6655; margin-top: 5px; }

  /* ── Tablet (max 768px) ── */
  @media (max-width: 768px) {
    .fs-section    { padding: 64px 24px; }
    .fs-outer      { grid-template-columns: 1fr 1fr; gap: 24px; }
    .fs-cards      { grid-column: 1 / -1; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .fs-img-wrap   { min-height: 320px; }
    .fs-img        { min-height: 320px; }
    .fs-eyebrow    { font-size: 11px; margin-bottom: 12px; }
    .fs-heading    { font-size: 26px; }
    .fs-body       { font-size: 14px; margin-top: 14px; }
    .fs-cta-btn    { font-size: 14px; padding: 13px 24px; margin-top: 22px; }
    .fs-card       { padding: 16px; gap: 12px; }
    .fs-card-title { font-size: 14px; }
    .fs-card-body  { font-size: 12.5px; }
  }

  /* ── Mobile (max 479px) ── */
  @media (max-width: 479px) {
    .fs-section    { padding: 48px 16px; }
    .fs-outer      { grid-template-columns: 1fr; }
    .fs-cards      { grid-template-columns: 1fr; }
    .fs-img-wrap   { min-height: 220px; }
    .fs-img        { min-height: 220px; }
    .fs-eyebrow    { font-size: 10px; }
    .fs-heading    { font-size: 22px; }
    .fs-body       { font-size: 13px; }
    .fs-cta-btn    { width: 100%; text-align: center; font-size: 14px; }
    .fs-card-title { font-size: 13.5px; }
    .fs-card-body  { font-size: 12px; }
  }

</style>

<script>
  const fsCards = document.querySelectorAll<HTMLElement>('.fs-card');
  const fsTimers = new Map<Element, ReturnType<typeof setTimeout>>();

  const fsObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const card = entry.target as HTMLElement;
        const i = parseInt(card.dataset.i ?? '0', 10);

        if (entry.isIntersecting) {
          const t = setTimeout(() => card.classList.add('in-view'), i * 150);
          fsTimers.set(card, t);
        } else {
          clearTimeout(fsTimers.get(card));
          fsTimers.delete(card);
          card.classList.remove('in-view');
        }
      });
    },
    { rootMargin: '0px 0px -18% 0px', threshold: 0 }
  );

  fsCards.forEach((card) => fsObserver.observe(card));
</script>