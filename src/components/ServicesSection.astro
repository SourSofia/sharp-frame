---
interface Props {
  items: Array<{ title: string; description: string; href?: string }>;
}
const { items } = Astro.props;
---
<section class="svc-section" style="background:#2D5A3D;margin-top:80px;">
  <div style="max-width:1200px;margin:0 auto">
    <div class="svc-header" style="display:grid;grid-template-columns:1.1fr 1fr;gap:56px;align-items:end;margin-bottom:56px">
      <h2 class="svc-heading" style="line-height:1.1;font-weight:800;color:#fff;letter-spacing:-0.02em">Local Advertising Solutions for Denver Businesses</h2>
      <p class="svc-subtext" style="line-height:1.65;color:#cfe0d3">As your trusted Denver marketing pros, our billboard network gives you access to high-traffic locations where your ideal customers spend time. From gyms and restaurants to retail stores and office buildings, we help you get noticed in the moments that matter.</p>
    </div>
    <div class="svc-cards-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px">
      {items.map((svc, i) => (
        <a href={svc.href ?? '#'} class="service-card" data-i={i} style="background:#fff;border-radius:16px;padding:28px;display:flex;flex-direction:column;gap:14px;min-height:230px;text-decoration:none;color:inherit">
          <div style="width:46px;height:46px;border-radius:12px;background:#FBEDE4;display:flex;align-items:center;justify-content:center">
            {svc.title === 'Indoor Billboard Advertising' ? (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C4622A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
              </svg>
            ) : svc.title === 'Social Media Marketing' ? (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C4622A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"/>
                <circle cx="6" cy="12" r="3"/>
                <circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
            ) : svc.title === 'Custom Website Design' ? (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C4622A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <line x1="3" y1="9" x2="21" y2="9"/>
                <line x1="9" y1="21" x2="9" y2="9"/>
              </svg>
            ) : svc.title === 'Targeted Lead Generation' ? (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C4622A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="4"/>
                <line x1="22" y1="12" x2="16" y2="12"/>
                <line x1="8" y1="12" x2="2" y2="12"/>
                <line x1="12" y1="2" x2="12" y2="8"/>
                <line x1="12" y1="16" x2="12" y2="22"/>
              </svg>
            ) : (
              <div style="width:18px;height:18px;border:2.5px solid #C4622A;border-radius:5px"></div>
            )}
          </div>
          <h3 class="card-title" style="font-weight:800;color:#C4622A;line-height:1.2">{svc.title}</h3>
          <p class="card-body" style="line-height:1.55;color:#4A6655">{svc.description}</p>
        </a>
      ))}
    </div>
    <div style="display:flex;justify-content:center;margin-top:48px">
      <a href="/solutions" class="services-cta-btn" style="background:#C4622A;color:#fff;font-weight:700;font-size:16px;padding:16px 34px;border-radius:999px;box-shadow:0 4px 6px rgba(140,55,12,0.6)">Explore our digital marketing services</a>
    </div>
  </div>
</section>

<style>
  /* ── Scroll animation ── */
  .service-card {
    min-height: unset !important;
    border: 2px solid transparent;
    opacity: 0;
    transform: translateX(60px);
    transition:
      opacity 1.1s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.1s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.2s ease;
  }
  .service-card.in-view {
    opacity: 1;
    transform: translateX(0);
  }

  .service-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 20px 24px -6px rgba(26, 51, 37, 0.65);
  }
  .icon-bg {
    transition: background-color 0.2s ease;
  }
  .service-card:hover .icon-bg {
    background: #fff !important;
  }
  .services-cta-btn {
    transition: transform 0.2s ease, background-color 0.2s ease;
  }
  .services-cta-btn:hover {
    transform: scale(1.06);
    background: #d8733d !important;
  }

  /* ── Desktop (1280px+) ── */
  .svc-section  { padding: 96px 40px; }

  /* ── Laptop L (1440px+) ── */
  @media (min-width: 1440px) {
    .svc-section { padding: 96px 80px; }
  }
  .svc-heading  { font-size: 42px; }
  .svc-subtext  { font-size: 16px; }
  .card-title   { font-size: 19px; }
  .card-body    { font-size: 15px; }

  /* ── Tablet (768px–1279px) ── */
  @media (max-width: 1279px) {
    .svc-section  { padding: 72px 24px; }
    .svc-cards-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 20px !important; }
    .svc-header   { grid-template-columns: 1fr !important; gap: 20px !important; margin-bottom: 36px !important; }
    .svc-heading  { font-size: 32px; }
    .svc-subtext  { font-size: 15px; }
    .card-title   { font-size: 17px; }
    .card-body    { font-size: 14px; }
  }

  /* ── Mobile (max 479px) ── */
  @media (max-width: 479px) {
    .svc-section  { padding: 56px 16px; }
    .svc-cards-grid { grid-template-columns: 1fr !important; }
    .svc-heading  { font-size: 26px; }
    .svc-subtext  { font-size: 14px; }
    .card-title   { font-size: 16px; }
    .card-body    { font-size: 13px; }
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.service-card');
  const timers = new Map<Element, ReturnType<typeof setTimeout>>();

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const card = entry.target as HTMLElement;
        const i = parseInt(card.dataset.i ?? '0', 10);

        if (entry.isIntersecting) {
          // Stagger each card 150ms apart so they slide in one by one
          const t = setTimeout(() => card.classList.add('in-view'), i * 150);
          timers.set(card, t);
        } else {
          // Cancel any pending timer and reset immediately
          clearTimeout(timers.get(card));
          timers.delete(card);
          card.classList.remove('in-view');
        }
      });
    },
    {
      rootMargin: '0px 0px -18% 0px',
      threshold: 0,
    }
  );

  cards.forEach((card) => observer.observe(card));
</script>