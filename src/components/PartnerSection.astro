---
import data from '../data/partner.json';
const { heading, body, cta } = data;
---

<section class="ps-section">
  <div class="ps-inner">
    <div class="ps-content">
      <div class="ps-eyebrow">Work With Us</div>
      <h2 class="ps-heading">{heading}</h2>
      <p class="ps-body">{body}</p>
      <a href={cta.href} class="ps-btn">{cta.label}</a>
    </div>
    <div class="ps-img-wrap">
      <img src="/images/boost-visibility 2.png" alt="Boost Visibility" class="ps-img" />
    </div>
  </div>
</section>

<style>
  .ps-section {
    background: url('/images/website-design.avif') center/cover no-repeat;
    padding: 96px 40px;
    position: relative;
  }

  .ps-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(140, 55, 12, 0.78);
  }

  .ps-inner {
    max-width: 860px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    background: #FBF7F4;
    box-shadow: 0 24px 48px -8px rgba(80, 30, 5, 0.45);
    border-radius: 24px;
    padding: 56px 64px;
    display: flex;
    align-items: center;
    gap: 40px;
    opacity: 0;
    transform: translateY(44px);
    transition: opacity 1.1s cubic-bezier(0.22, 1, 0.36, 1), transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ps-inner.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  .ps-content { flex: 1; min-width: 0; }

  .ps-img-wrap {
    flex-shrink: 0;
    width: 280px;
    height: 280px;
    border-radius: 16px;
    overflow: hidden;
  }

  .ps-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ps-eyebrow {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #C4622A;
    margin-bottom: 16px;
  }

  .ps-heading {
    font-size: 36px;
    font-weight: 800;
    line-height: 1.08;
    color: #1A3325;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .ps-body {
    font-size: 16px;
    line-height: 1.7;
    color: #4A6655;
    margin-bottom: 36px;
  }

  .ps-btn {
    display: inline-block;
    background: #C4622A;
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    padding: 16px 36px;
    border-radius: 999px;
    text-decoration: none;
    box-shadow: 0 4px 6px rgba(140,55,12,0.6);
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .ps-btn:hover {
    transform: scale(1.06);
    background: #d8733d;
  }

  /* ── Tablet (max 768px) ── */
  @media (max-width: 768px) {
    .ps-section  { padding: 72px 24px; }
    .ps-inner    { padding: 40px 36px; margin: 0; flex-direction: column; }
    .ps-img-wrap { width: 100%; height: 200px; }
    .ps-heading  { font-size: 26px; }
    .ps-body     { font-size: 15px; margin-bottom: 28px; }
    .ps-eyebrow  { font-size: 11px; }
  }

  /* ── Mobile (max 479px) ── */
  @media (max-width: 479px) {
    .ps-section  { padding: 56px 16px; }
    .ps-inner    { padding: 32px 24px; border-radius: 18px; gap: 28px; }
    .ps-heading  { font-size: 22px; }
    .ps-body     { font-size: 14px; }
    .ps-btn      { width: 100%; text-align: center; font-size: 15px; }
  }
</style>

<script>
  const psCard = document.querySelector('.ps-inner');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
        } else {
          entry.target.classList.remove('in-view');
        }
      });
    },
    { rootMargin: '0px 0px -18% 0px', threshold: 0 }
  );
  if (psCard) observer.observe(psCard);
</script>
