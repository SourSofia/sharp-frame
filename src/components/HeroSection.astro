---
// Accepts custom metadata text properties if configured down the line
---

<section class="sf-hero-section">
  <div class="sf-hero-wrap">
    <img
      src="/images/home.avif"
      alt="Denver skyline"
      class="sf-hero-img"
    />
    <div class="sf-hero-card">
      <div class="sf-hero-eyebrow">Premium Marketing Solutions</div>
      <h1 class="sf-hero-h1">Local Advertising &amp; Digital Marketing Pros in Denver</h1>
      <p class="sf-hero-p">Helping businesses get noticed — on screens and online.</p>
      <a href="#" class="hero-cta-btn sf-hero-btn">Talk to our team</a>
    </div>
  </div>
</section>

<style is:global>
  /* ── Mobile (base) ── */
  .sf-hero-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 16px 0;
  }

  .sf-hero-wrap {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
  }

  .sf-hero-img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    display: block;
  }

  .sf-hero-card {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: calc(100% - 48px);
    max-width: 340px;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(6px);
    border-radius: 18px;
    padding: 24px 22px;
    box-shadow: 0 20px 48px -8px rgba(26,51,37,0.45);
  }

  .sf-hero-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #C4622A;
    margin-bottom: 10px;
  }

  .sf-hero-h1 {
    font-size: 26px;
    line-height: 1.1;
    font-weight: 800;
    color: #1A3325;
    letter-spacing: -0.02em;
  }

  .sf-hero-p {
    font-size: 14px;
    line-height: 1.55;
    color: #4A6655;
    margin-top: 10px;
  }

  .sf-hero-btn {
    display: inline-block;
    margin-top: 18px;
    background: #C4622A;
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    padding: 12px 24px;
    border-radius: 999px;
    box-shadow: 0 4px 6px rgba(140,55,12,0.6);
  }

  /* ── Mobile S (320px–375px) ── */
  @media (max-width: 375px) {
    .sf-hero-img  { height: 400px; }
    .sf-hero-card { padding: 20px 16px; width: calc(100% - 32px); }
    .sf-hero-eyebrow { font-size: 10px; margin-bottom: 8px; }
    .sf-hero-h1   { font-size: 22px; }
    .sf-hero-p    { font-size: 13px; margin-top: 8px; }
    .sf-hero-btn  { font-size: 13px; padding: 11px 20px; margin-top: 14px; }
  }

  /* ── Tablet (768px+) ── */
  @media (min-width: 768px) {
    .sf-hero-section { padding: 32px 24px 0; }

    .sf-hero-img { height: 480px; }

    .sf-hero-card {
      top: auto;
      bottom: 28px;
      left: 28px;
      right: auto;
      transform: none;
      max-width: 380px;
      padding: 24px 28px;
    }

    .sf-hero-eyebrow { font-size: 12px; margin-bottom: 10px; }
    .sf-hero-h1      { font-size: 30px; }
    .sf-hero-p       { font-size: 14px; margin-top: 10px; }
    .sf-hero-btn     { font-size: 14px; padding: 12px 24px; margin-top: 16px; }
  }

  /* ── Desktop (1280px+) ── */
  @media (min-width: 1280px) {
    .sf-hero-section { padding: 32px 40px 0; }

    .sf-hero-img { height: 560px; }

    .sf-hero-card {
      bottom: 40px;
      left: 48px;
      max-width: 480px;
      padding: 32px 36px;
    }

    .sf-hero-eyebrow { font-size: 13px; margin-bottom: 12px; }
    .sf-hero-h1      { font-size: 42px; line-height: 1.05; }
    .sf-hero-p       { font-size: 16px; margin-top: 12px; }
    .sf-hero-btn     { font-size: 15px; padding: 14px 28px; margin-top: 20px; }
  }

  /* ── Button interactions ── */
  .hero-cta-btn {
    transition: transform 0.2s ease, background-color 0.2s ease;
  }
  .hero-cta-btn:hover {
    transform: scale(1.06);
    background: #d8733d !important;
  }
</style>
