---
interface Props {
  items: Array<{ question: string; answer: string }>;
}
const { items } = Astro.props;
---
<section style="background:#2D5A3D;padding:96px 40px">
  <div style="max-width:820px;margin:0 auto">
    <div style="text-align:center;margin-bottom:48px">
      <div style="font-size:13px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#fff;margin-bottom:14px">FAQs</div>
      <h2 style="font-size:40px;line-height:1.1;font-weight:800;color:#e4eee6;letter-spacing:-0.02em">Questions? We've Got Answers</h2>
    </div>
    <div style="display:flex;flex-direction:column;gap:16px">
      {items.map((item, i) => (
        <div class="faq-item" data-i={i}>
          <button class="faq-trigger" aria-expanded="false">
            <span class="faq-question">{item.question}</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-body-wrapper">
            <div class="faq-body-inner">
              <p class="faq-answer">{item.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-item {
    background: #ebf1e9;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    overflow: hidden;
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 1s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .faq-item.in-view {
    opacity: 1;
    transform: translateY(0);
  }
  .faq-item.in-view:hover {
    transform: scale(1.02);
    transition: transform 0.2s ease;
  }

  .faq-trigger {
    width: 100%;
    cursor: pointer;
    padding: 26px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    background: none;
    border: none;
    font-family: inherit;
    text-align: left;
  }

  .faq-question {
    font-size: 18px;
    font-weight: 700;
    color: #1A3325;
    line-height: 1.35;
  }

  .faq-icon {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    box-sizing: border-box;
    padding-bottom: 4px;
    border-radius: 999px;
    background: #FBEDE4;
    color: #C4622A;
    font-size: 22px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    transition: transform 0.3s ease;
  }

  .faq-trigger[aria-expanded="true"] .faq-icon {
    transform: rotate(45deg);
  }

  .faq-body-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }

  .faq-trigger[aria-expanded="true"] + .faq-body-wrapper {
    grid-template-rows: 1fr;
  }

  .faq-body-inner {
    overflow: hidden;
  }

  .faq-answer {
    padding: 0 28px 28px;
    font-size: 16px;
    line-height: 1.65;
    color: #4A6655;
    margin: 0;
  }
</style>

<script>
  // Accordion
  document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!expanded));
    });
  });

  // Float-up animation
  const faqItems = document.querySelectorAll<HTMLElement>('.faq-item');
  const faqTimers = new Map<Element, ReturnType<typeof setTimeout>>();

  const faqObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const el = entry.target as HTMLElement;
        const i = parseInt(el.dataset.i ?? '0', 10);
        if (entry.isIntersecting) {
          const t = setTimeout(() => el.classList.add('in-view'), i * 120);
          faqTimers.set(el, t);
        } else {
          clearTimeout(faqTimers.get(el));
          faqTimers.delete(el);
          el.classList.remove('in-view');
        }
      });
    },
    { rootMargin: '0px 0px -18% 0px', threshold: 0 }
  );

  faqItems.forEach((el) => faqObserver.observe(el));
</script>
